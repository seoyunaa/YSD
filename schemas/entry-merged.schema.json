{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entry-merged.schema.json",
  "description": "Layer 4: base + annotation 병합 결과. 수동 편집 금지 — merge_annotations.ps1로 재생성.",
  "type": "object",
  "required": ["id", "work_id", "sequence", "kind", "text"],
