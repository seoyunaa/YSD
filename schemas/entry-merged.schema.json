    "id": { "type": "string" },
    "work_id": { "type": "string" },
    "sequence": { "type": "integer" },
    "kind": { "type": "string" },
    "head": { "type": "string" },
    "month_context": { "type": "object" },
    "date": { "type": "object" },
    "weather": { "type": "object" },
    "mobility": { "type": "object" },
    "text_pointer": { "type": "object" },
    "text": { "type": "string" },
    "summary_ko": { "type": "string" },
    "persons": { "type": "array" },
    "places": { "type": "array" },
    "offices": { "type": "array" },
    "institutions": { "type": "array" },
    "documents": { "type": "array" },
    "works": { "type": "array" },
    "consumables": { "type": "array" },
    "topics": { "type": "array" },
    "notes": { "type": "array" },
    "status": { "type": "object" },
    "provenance": { "type": "object" }
  }
}
